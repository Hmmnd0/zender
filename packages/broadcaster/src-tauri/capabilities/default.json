{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Zender Broadcaster default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-home-read",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write",
    "fs:allow-home-write-recursive",
    "fs:allow-home-meta",
    "fs:allow-home-meta-recursive",
    "shell:default",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "node", "cmd": "node", "args": true, "sidecar": false }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "node", "cmd": "node", "args": true, "sidecar": false }
      ]
    }
  ]
}
