{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zender",
  "version": "0.1.0",
  "identifier": "com.zender.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zender",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      },
      {
        "label": "miniplayer",
        "title": "Zender",
        "width": 360,
        "height": 72,
        "minWidth": 280,
        "minHeight": 72,
        "maxHeight": 72,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "miniplayer.html"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
